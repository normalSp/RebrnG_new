{
  "name": "rebrng-new",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r build",
    "content:build": "cargo run -p rebrng-content-tools -- build-s0 --input content/s0 --output target/rebrng-content/s0.bundle.json",
    "desktop:build": "pnpm --filter @rebrng/desktop tauri build",
    "desktop:dev": "pnpm --filter @rebrng/desktop tauri dev",
    "deepseek:generate": "node scripts/deepseek-candidates.mjs generate --mock --out .local/deepseek-candidates",
    "deepseek:review": "node scripts/deepseek-candidates.mjs review --dir .local/deepseek-candidates",
    "deepseek:validate": "node scripts/deepseek-candidates.mjs validate --dir .local/deepseek-candidates",
    "deepseek:test": "node --test scripts/deepseek-candidates.test.mjs",
    "canon:source-map": "node scripts/extract-canon-source-map.mjs --source reverend-insanity.txt --out docs/superpowers/data/canon/first-volume-source-map.json",
    "canon:validate": "node scripts/validate-canon-index.mjs",
    "canon:test": "node --test scripts/extract-canon-source-map.test.mjs && node scripts/validate-canon-index.mjs",
    "check": "pnpm -r build && cargo test --workspace"
  }
}
